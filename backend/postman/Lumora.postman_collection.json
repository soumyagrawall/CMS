{
  "info": {
    "name": "Lumora API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Handoff collection for Lumora backend demo/MVP APIs."
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "request": { "method": "GET", "url": "{{baseUrl}}/health" }
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Demo Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('login success', () => pm.expect(json.success).to.eql(true));",
                  "pm.collectionVariables.set('token', json.data.token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"email\":\"demo@lumora.test\",\"password\":\"demo12345\"}" },
            "url": "{{baseUrl}}/api/v1/auth/login"
          }
        },
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"fullName\":\"Demo Creator\",\"username\":\"demo_creator\",\"email\":\"demo@lumora.test\",\"password\":\"demo12345\"}" },
            "url": "{{baseUrl}}/api/v1/auth/signup"
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "url": "{{baseUrl}}/api/v1/auth/me"
          }
        }
      ]
    },
    {
      "name": "Images",
      "item": [
        {
          "name": "Feed",
          "request": {
            "method": "GET",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "url": "{{baseUrl}}/api/v1/images/feed"
          }
        },
        {
          "name": "Image Detail",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/images/1" }
        },
        {
          "name": "Upload Image",
          "request": {
            "method": "POST",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title", "value": "Uploaded Demo", "type": "text" },
                { "key": "caption", "value": "Demo upload caption", "type": "text" },
                { "key": "tags", "value": "demo,upload", "type": "text" },
                { "key": "image", "type": "file", "src": [] }
              ]
            },
            "url": "{{baseUrl}}/api/v1/images/upload"
          }
        }
      ]
    },
    {
      "name": "AI",
      "item": [
        {
          "name": "Generate Image",
          "request": {
            "method": "POST",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"prompt\":\"editorial studio light\",\"style\":\"editorial\",\"title\":\"Demo Creation\",\"tags\":[\"demo\"]}" },
            "url": "{{baseUrl}}/api/v1/ai/images/generate"
          }
        },
        {
          "name": "Generate Caption",
          "request": {
            "method": "POST",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"prompt\":\"editorial studio light\",\"title\":\"Demo Creation\",\"tags\":[\"demo\"]}" },
            "url": "{{baseUrl}}/api/v1/ai/captions/generate"
          }
        }
      ]
    },
    {
      "name": "Social",
      "item": [
        {
          "name": "Like",
          "request": {
            "method": "POST",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "url": "{{baseUrl}}/api/v1/social/images/1/like"
          }
        },
        {
          "name": "Save",
          "request": {
            "method": "POST",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "url": "{{baseUrl}}/api/v1/social/images/1/save"
          }
        },
        {
          "name": "List Comments",
          "request": {
            "method": "GET",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "url": "{{baseUrl}}/api/v1/social/images/1/comments"
          }
        },
        {
          "name": "Add Comment",
          "request": {
            "method": "POST",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"body\":\"Postman demo comment\"}" },
            "url": "{{baseUrl}}/api/v1/social/images/1/comments"
          }
        }
      ]
    },
    {
      "name": "Search",
      "request": {
        "method": "GET",
        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
        "url": "{{baseUrl}}/api/v1/search?q=architecture"
      }
    },
    {
      "name": "Analytics Event",
      "request": {
        "method": "POST",
        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\"imageId\":1,\"eventType\":\"share\",\"metadata\":{\"surface\":\"postman\"}}" },
        "url": "{{baseUrl}}/api/v1/analytics/events"
      }
    },
    {
      "name": "Notifications",
      "request": {
        "method": "GET",
        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
        "url": "{{baseUrl}}/api/v1/notifications"
      }
    }
  ]
}
