# Server Configuration
NODE_ENV=development
PORT=5000
API_BASE_URL=http://localhost:5000
FRONTEND_ORIGIN=http://localhost:5000

# Database Configuration (Replace with your PaaS/Local DB credentials)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=YOUR_DB_PASSWORD_HERE
DB_NAME=lumora
DB_CONNECTION_LIMIT=10
REQUIRE_DB_ON_START=false

# Demo Accounts
DEMO_AUTH_ENABLED=false
DEMO_EMAIL=demo@lumora.test
DEMO_PASSWORD=demo12345

# Authentication / Security
JWT_SECRET=YOUR_RANDOM_JWT_SECRET_HERE
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

# Local Storage (Fallback)
UPLOAD_DIR=uploads/images
MAX_UPLOAD_MB=8

# AI Integrations
AI_PROVIDER=mock
AI_API_KEY=

# AWS S3 Cloud Storage Credentials (Do NOT commit real keys)
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_HERE
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY_HERE
AWS_REGION=YOUR_AWS_REGION_HERE
AWS_BUCKET_NAME=YOUR_S3_BUCKET_NAME_HERE
